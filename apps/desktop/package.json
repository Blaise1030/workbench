{
  "name": "workbench",
  "version": "0.11.0",
  "private": true,
  "type": "commonjs",
  "description": "Desktop workspace for local coding agents",
  "author": "workbench contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blaise1030/workbench.git"
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node ./build/runViteDev.cjs",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "concurrently -k \"pnpm run dev\" \"pnpm run dev:electron:tsc\" \"pnpm run dev:electron:run\"",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "node ./build/runElectronDev.cjs",
    "build": "vue-tsc --noEmit && vite build",
    "analyze": "vue-tsc --noEmit && cross-env ANALYZE=1 vite build",
    "verify:bundle-budget": "pnpm run build && pnpm exec tsx scripts/verify-bundle-budget.ts",
    "build:app": "pnpm run build && pnpm run build:electron",
    "dist": "pnpm run build:app && electron-builder",
    "dist:dir": "pnpm run build:app && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:natives": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/suggestion": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-vue": "^8.6.0",
    "fuse.js": "^7.3.0",
    "geist": "^1.7.0",
    "lucide-vue-next": "^1.0.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-input-otp": "^0.3.2",
    "vue-router": "4",
    "vue-sonner": "^2.0.9",
    "xterm": "^5.3.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "39.8.5",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3"
  }
}
