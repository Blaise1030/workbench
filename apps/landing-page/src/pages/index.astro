---
import "../styles/global.css";
import {
	GITHUB_API_LATEST_RELEASE_URL,
	GITHUB_REPO_URL,
	LATEST_RELEASE_JSON_URL,
	LATEST_RELEASE_PAGE_URL,
} from "../constants/releases";

/** Same as `apps/desktop/src/constants/appMeta.ts` — threads panel header title */
const APP_DISPLAY_NAME = "workbench";

interface ReleaseManifest {
	version?: string;
	downloads?: Record<string, { url: string; filename: string }>;
}

let releaseManifest: ReleaseManifest = {};
try {
	const res = await fetch(LATEST_RELEASE_JSON_URL);
	if (res.ok) releaseManifest = await res.json() as ReleaseManifest;
} catch { /* use fallback */ }

const ssrDownloadUrl = releaseManifest.downloads?.mac?.url ?? LATEST_RELEASE_PAGE_URL;
const ssrVersion = releaseManifest.version;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/workbench-logo.png" />
		<link rel="apple-touch-icon" href="/workbench-logo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="workbench — a desktop workspace for local coding agents. Projects, agent threads, terminal, and editor in one native app."
		/>
		<title>workbench — Desktop workspace for coding agents</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bungee+Shade&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="relative overflow-x-hidden">
		<header class="bg-transparent">
			<div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-2.5">
				<a href="/" class="flex min-w-0 flex-1 items-center gap-1 overflow-hidden" aria-label={`${APP_DISPLAY_NAME} home`}>
					<h2
						class="relative m-0 flex min-w-0 flex-1 flex-nowrap items-center gap-1 overflow-hidden p-0 text-zinc-900"
						data-testid="thread-sidebar-brand"
					>
						<img
							src="/workbench-logo.png"
							alt=""
							width="32"
							height="32"
							loading="eager"
							decoding="async"
							draggable="false"
							class="pointer-events-none size-8 shrink-0 select-none rounded-lg object-cover"
							aria-hidden="true"
							data-testid="thread-sidebar-logo"
						/>
						<span
							class="font-app-brand-title block min-w-0 truncate text-base uppercase leading-none text-zinc-900"
							data-testid="app-title-a11y"
						>
							{APP_DISPLAY_NAME}
						</span>
						<span
							class="shadow-xs ms-0.5 mt-0.5 inline-flex h-3.5 min-h-0 shrink-0 items-center justify-center rounded-sm border border-zinc-200 bg-transparent px-1 py-0 text-[8px] font-semibold uppercase leading-none tracking-wide text-zinc-900"
							data-testid="thread-sidebar-alpha-badge"
						>
							Alpha
						</span>
					</h2>
				</a>
				<a
					href={GITHUB_REPO_URL}
					class="shrink-0 text-sm font-medium text-zinc-500 transition hover:text-zinc-900"
					rel="noopener noreferrer"
				>
					GitHub <span aria-hidden="true" class="opacity-70">↗</span>
				</a>
			</div>
		</header>

		<main class="px-2">
			<section class="mx-auto max-w-5xl px-6 pb-16 pt-16 text-center md:pb-20 md:pt-20" aria-labelledby="hero-heading">
				<h1 id="hero-heading" class="mx-auto max-w-5xl text-balance text-4xl font-medium leading-[1.1] tracking-tight text-zinc-900 md:text-5xl lg:text-[3.25rem]">
					workbench is the best way to code with agents on your machine.
				</h1>
				<p class="mx-auto mt-5 max-w-3xl text-lg text-zinc-600">
					A native desktop workbench: projects, agent threads, integrated terminal, and editor—so local agents can plan, run commands, and land changes where your code already lives.
				</p>
				<div id="download" class="mt-10 flex flex-col items-center gap-2">
					<a
						id="download-btn"
						href={ssrDownloadUrl}
						class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-zinc-900/15 transition hover:bg-zinc-800"
						rel="noopener noreferrer"
					>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path
								d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
							/>
						</svg>
						<span id="download-btn-label">Download for macOS</span>
					</a>
					<p id="download-version" class={`text-xs text-zinc-500${ssrVersion ? "" : " hidden"}`} aria-live="polite">
						{ssrVersion ? `Version ${ssrVersion}` : ""}
					</p>
				</div>
			</section>

			<section class="mx-auto max-w-5xl pb-12" aria-labelledby="preview-heading">
				<h2 id="preview-heading" class="sr-only">Product preview</h2>
				<div
					class=" flex flex-col overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-lg shadow-zinc-900/5"
				>
					<div
						class="shrink-0 border-b border-zinc-200/80 bg-zinc-50/95 px-4 py-3 text-center text-xs text-zinc-600"
					>
						workbench — breeze through local projects, agent threads, terminal, and editor in one window.
					</div>
					<div class="group relative flex overflow-hidden rounded-[10px] bg-zinc-100">
						<img
							src="/clip-1775663897128.png"
							alt="workbench screenshot with annotations highlighting project bar, worktree resources, and multi-CLI support."
							loading="lazy"
                            class="max-w-5xl"
							decoding="async"
							draggable="false"
						/>
						<img
							src="/clip-1775663906452.png"
							alt="workbench interface screenshot without annotations."
							class="max-w-5xl pointer-events-none absolute object-contain object-top opacity-0 transition-opacity duration-300 ease-out motion-reduce:transition-none group-hover:opacity-100"
							loading="lazy"                            
							decoding="async"
							aria-hidden="true"
							draggable="false"
						/>
					</div>
				</div>
			</section>
		</main>

		<footer class="border-t border-zinc-200/80 bg-white py-10">
			<div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 text-sm text-zinc-500 md:flex-row">
				<p>© {new Date().getFullYear()} workbench</p>
				<div class="flex gap-6">
					<a href={GITHUB_REPO_URL} class="text-zinc-500 transition hover:text-zinc-900" rel="noopener noreferrer">
						GitHub
					</a>
				</div>
			</div>
		</footer>

		<script>
			const preview = document.querySelector(".preview-scale-in");
			if (preview) {
				if ("IntersectionObserver" in window) {
					const io = new IntersectionObserver(
						(entries) => {
							for (const e of entries) {
								if (e.isIntersecting) {
									e.target.classList.add("preview-scale-in--visible");
									io.disconnect();
								}
							}
						},
						{ root: null, rootMargin: "0px 0px -8% 0px", threshold: 0.12 }
					);
					io.observe(preview);
				} else {
					preview.classList.add("preview-scale-in--visible");
				}
			}
		</script>

		<script
			define:vars={{
				SSR_MANIFEST: releaseManifest,
				LATEST_RELEASE_PAGE_URL,
			}}
		>
			function pickPlatform() {
				const ua = navigator.userAgent.toLowerCase();
				if (/\bwin\b/.test(ua) || /windows/.test(ua)) return "windows";
				if (/macintosh|mac os x|mac os/.test(ua)) return "mac";
				if (/linux/.test(ua)) return "linux";
				return "mac";
			}

			function labelForPlatform(p) {
				if (p === "windows") return "Download for Windows";
				if (p === "linux") return "Download for Linux";
				return "Download for macOS";
			}

			(() => {
				const btn = document.getElementById("download-btn");
				const labelEl = document.getElementById("download-btn-label");
				const versionEl = document.getElementById("download-version");
				if (!btn || !labelEl) return;

				const platform = pickPlatform();
				labelEl.textContent = labelForPlatform(platform);

				const entry = SSR_MANIFEST?.downloads?.[platform];
				if (entry?.url) {
					btn.setAttribute("href", entry.url);
				} else {
					btn.setAttribute("href", LATEST_RELEASE_PAGE_URL);
				}

				if (versionEl && SSR_MANIFEST?.version) {
					versionEl.textContent = `Version ${SSR_MANIFEST.version}`;
					versionEl.classList.remove("hidden");
				}
			})();
		</script>
	</body>
</html>
