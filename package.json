{
  "name": "cli-agent-workspace-poc",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Desktop workspace POC for local coding agents",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite --strictPort --port 5180",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "concurrently -k \"npm run dev\" \"npm run dev:electron:tsc\" \"npm run dev:electron:run\"",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5180 file:dist-electron/electron/main.js file:dist-electron/electron/preload.js file:dist-electron/src/shared/ipc.js && cross-env ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://localhost:5180 electron dist-electron/electron/main.js",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "diff2html": "^3.4.56",
    "electron": "^35.1.5",
    "lucide-vue-next": "^1.0.0",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.14",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3"
  }
}
