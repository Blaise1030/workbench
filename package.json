{
  "name": "workbench",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Desktop workspace for local coding agents",
  "author": "workbench contributors",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite --strictPort --port 5180",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "concurrently -k \"npm run dev\" \"npm run dev:electron:tsc\" \"npm run dev:electron:run\"",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5180 file:dist-electron/electron/main.js file:dist-electron/electron/mainApp.js file:dist-electron/electron/preload.js file:dist-electron/src/shared/ipc.js && cross-env ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://localhost:5180 electron dist-electron/electron/main.js",
    "build": "vue-tsc --noEmit && vite build",
    "build:app": "npm run build && npm run build:electron",
    "dist": "npm run build:app && electron-builder",
    "dist:dir": "npm run build:app && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:natives": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.9.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/search": "^6.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "codemirror": "^6.0.2",
    "diff2html": "^3.4.56",
    "dompurify": "^3.3.3",
    "geist": "^1.7.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^17.0.6",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.14",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3"
  }
}
