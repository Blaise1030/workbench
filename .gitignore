# Dependencies (never commit — includes Electron binary ~150MB+)
node_modules/

# electron-builder output (installers / unpacked app)
release/
apps/desktop/release/

# Compiled Electron output (regenerate with npm run build:electron)
dist-electron/*
apps/desktop/dist-electron/*

# Vite frontend build
dist/
apps/desktop/dist/

# Local / secrets
.env
.env.*
!.env.example

# Logs & OS noise
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Local bundle analysis (pnpm --filter workbench analyze)
apps/desktop/bundle-stats/

# Test / tooling caches
coverage/
.vitest/
*.tsbuildinfo

# Local git worktrees
.worktrees/
.worktrees
worktrees
